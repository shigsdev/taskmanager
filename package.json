{
  "name": "taskmanager-js-tests",
  "version": "1.0.0",
  "private": true,
  "description": "Jest unit tests + Playwright E2E tests for Task Manager JavaScript",
  "scripts": {
    "test": "jest",
    "test:verbose": "jest --verbose",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:headed": "playwright test --project=chromium --headed",
    "test:e2e:prod": "playwright test --project=chromium-prod",
    "test:e2e:sw": "playwright test --project=chromium-sw",
    "test:e2e:mobile": "playwright test --project=chromium-mobile"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  }
}
