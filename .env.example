# Copy to .env for local dev. Never commit .env.
# All real values live in the Railway dashboard in production.

# Flask
SECRET_KEY=change-me-to-a-random-32-char-string
FLASK_ENV=development

# Allow OAuth over http for local dev only. Do NOT set in production.
OAUTHLIB_INSECURE_TRANSPORT=1

# Single-user lockdown: the only Google account allowed to log in.
AUTHORIZED_EMAIL=you@gmail.com

# Google OAuth (from console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Encryption (Fernet key — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# Database (Railway injects DATABASE_URL in production)
DATABASE_URL=sqlite:///dev.db

# Email digest — sent via authenticated SMTP (Gmail by default; ADR-035).
# For Gmail: enable 2-Step Verification, create an App Password, and put
# your Gmail address in SMTP_USERNAME + the 16-char App Password in
# SMTP_PASSWORD. SMTP_HOST/PORT default to Gmail's submission endpoint.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
DIGEST_TO_EMAIL=
# From address; defaults to SMTP_USERNAME if left blank (Gmail requires
# the From to be the authenticated account or a verified alias).
DIGEST_FROM_EMAIL=
DIGEST_TIME=07:00

# Image scan
GOOGLE_VISION_API_KEY=
ANTHROPIC_API_KEY=

# #223 — /utilities backup-trigger + restore-drill cards. Fine-grained
# PAT with `Actions: read & write` permission on the taskmanager repo
# only. Create at https://github.com/settings/personal-access-tokens.
# Used by utilities_api.py to POST to GitHub's workflow_dispatch endpoint
# for `daily-backup.yml` and `monthly-restore-drill.yml`. Optional —
# the dispatch endpoints return HTTP 503 with a clear setup message
# when this var is unset.
GITHUB_DISPATCH_TOKEN=
# Optional override (defaults to shigsdev/taskmanager). Set this if you
# forked the repo and want the dispatch endpoints to fire workflows on
# your fork's Actions.
# GITHUB_REPO=shigsdev/taskmanager
