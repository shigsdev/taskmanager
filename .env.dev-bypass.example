# Copy this file to .env.dev-bypass to enable a local browser-testing
# session where the agent (or you) can hit protected pages without
# completing real Google OAuth.
#
# The actual .env.dev-bypass file is gitignored. The file's existence
# is the on/off switch — delete it when you're done testing.
#
# See README.md "Local browser testing with bypass mode" for the full
# SOP, and auth.py for the gate logic.

LOCAL_DEV_BYPASS_AUTH=1
