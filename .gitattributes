# Normalize line endings: LF in the repo, native on checkout
* text=auto

# Force LF for files that must stay consistent across OS
*.py text eol=lf
*.js text eol=lf
*.html text eol=lf
*.css text eol=lf
*.toml text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.sh text eol=lf
Procfile text eol=lf

# Binary files — don't touch
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.xlsx binary
*.docx binary
*.woff binary
*.woff2 binary
